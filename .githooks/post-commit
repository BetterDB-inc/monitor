#!/bin/sh
# roborev post-commit hook v4 - auto-reviews every commit
ROBOREV="/home/kristiyan/.local/bin/roborev"
if [ ! -x "$ROBOREV" ]; then
    ROBOREV=$(command -v roborev 2>/dev/null)
    [ -z "$ROBOREV" ] || [ ! -x "$ROBOREV" ] && exit 0
fi
"$ROBOREV" post-commit 2>/dev/null

# Open roborev stream in a new terminal
case "$(uname -s)" in
    Darwin)
        open -a Terminal.app "$ROBOREV" --args stream >/dev/null 2>&1 &
        ;;
    Linux)
        konsole -e "$ROBOREV" stream >/dev/null 2>&1 &
        ;;
esac
disown 2>/dev/null
