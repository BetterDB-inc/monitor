generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  community
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete
  incomplete_expired
  unpaid
  paused
}

model Customer {
  id             String   @id @default(cuid())
  // NB: also covered by a raw UNIQUE INDEX ON (LOWER(email)) — see the
  // email_case_uniqueness migration — because lookups are case-insensitive
  // and case-variant duplicates would conflate accounts.
  email          String   @unique
  name           String?
  stripeId       String?  @unique @map("stripe_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  licenses       License[]
  subscriptions  Subscription[]
  tenants        Tenant[]

  @@map("customers")
}

enum TenantStatus {
  pending
  provisioning
  ready
  error
  suspended
  deleting
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  subdomain     String       @unique
  email         String
  status        TenantStatus @default(pending)
  statusMessage String?      @map("status_message")
  customerId    String?      @map("customer_id")
  dbSchema      String       @map("db_schema")
  imageTag      String       @default("latest") @map("image_tag")
  domain        String?      @unique
  isDemo        Boolean      @default(false) @map("is_demo")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  customer        Customer?        @relation(fields: [customerId], references: [id])
  users           User[]
  invitations     Invitation[]
  valkeyInstances ValkeyInstance[]

  @@index([subdomain])
  @@index([status])
  @@index([customerId])
  @@map("tenants")
}

enum ValkeyInstanceStatus {
  pending
  provisioning
  ready
  error
  suspended
  deleting
}

model ValkeyInstance {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  // Friendly display name, unique per tenant (see @@unique below). The public
  // SNI host is an opaque hash derived from `id`, not the name, so two tenants
  // can reuse the same name without colliding on the shared wildcard endpoint.
  name          String
  status        ValkeyInstanceStatus @default(pending)
  statusMessage String?              @map("status_message")
  // Public TLS endpoint (opaque hash host), populated once provisioning reaches
  // `ready`. Unique because every instance shares the valkey.app.betterdb.com
  // wildcard, so the SNI host must be globally unique.
  host          String?              @unique
  port          Int                  @default(6379)
  // Name of the K8s Secret (password + users.acl) in the tenant namespace.
  secretName    String               @map("secret_name")
  username      String
  maxmemory     String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@map("valkey_instances")
}

model License {
  id             String   @id @default(cuid())
  key            String   @unique
  customerId     String   @map("customer_id")
  tier           Tier
  instanceLimit  Int      @default(1) @map("instance_limit")
  expiresAt      DateTime? @map("expires_at")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  validations    LicenseValidation[]
  offlineIssuances OfflineLicenseIssuance[]
  keyReveals     LicenseKeyReveal[]

  @@index([customerId])
  @@index([key])
  @@index([active])
  @@map("licenses")
}

// Audit of full-key reveals from the account page. The raw key is perpetual
// and reusable, so every reveal is recorded.
model LicenseKeyReveal {
  id              String    @id @default(cuid())
  // SetNull (not Cascade): the audit row must OUTLIVE the license/customer it
  // references — deleting a license must not erase the record of who revealed
  // its key. licenseId is nulled on delete, so we ALSO snapshot a durable,
  // non-FK identifier (licenseKeyLast4) captured at reveal time — otherwise a
  // deleted license leaves only email+timestamp with no way to tell WHICH
  // license's key was revealed. who/when + the snapshot survive the delete.
  licenseId       String?   @map("license_id")
  // Last 4 chars of the revealed key — enough to identify the license in the
  // audit trail without storing the secret; survives license deletion.
  licenseKeyLast4 String?   @map("license_key_last4")
  revealedToEmail String    @map("revealed_to_email")
  createdAt       DateTime  @default(now()) @map("created_at")

  license         License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([licenseId])
  @@map("license_key_reveals")
}

// Audit of issued offline (air-gapped) license tokens. Offline tokens are
// irrevocable until their exp, so every issuance is recorded for visibility.
model OfflineLicenseIssuance {
  id            String    @id @default(cuid())
  // SetNull (not Cascade): audit outlives the license — an offline token is
  // irrevocable for up to 366 days, so the record of who was issued one must
  // survive a license/customer delete. licenseId is nulled then; jti/kid still
  // identify the issued TOKEN, and licenseKeyLast4 snapshots WHICH license.
  licenseId     String?   @map("license_id")
  // Last 4 chars of the license key at issuance — identifies the license in the
  // audit trail after a delete nulls licenseId; not the secret itself.
  licenseKeyLast4 String? @map("license_key_last4")
  jti           String    @unique
  kid           String
  issuedToEmail String    @map("issued_to_email")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  license       License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([licenseId])
  @@map("offline_license_issuances")
}

model Subscription {
  id                String   @id @default(cuid())
  customerId        String   @map("customer_id")
  stripeSubscriptionId String @unique @map("stripe_subscription_id")
  stripePriceId     String   @map("stripe_price_id")
  stripeEventId     String?  @unique @map("stripe_event_id")
  tier              Tier
  status            SubscriptionStatus
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  cancelAtPeriodEnd  Boolean  @default(false) @map("cancel_at_period_end")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

model LicenseValidation {
  id          String   @id @default(cuid())
  licenseId   String   @map("license_id")
  instanceId  String   @map("instance_id")
  version     String?
  platform    String?
  nodeVersion String?  @map("node_version")
  validatedAt DateTime @default(now()) @map("validated_at")

  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([instanceId])
  @@index([validatedAt])
  @@map("license_validations")
}

enum AuthProvider {
  google
  github
}

enum UserRole {
  admin
  member
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  avatarUrl   String?      @map("avatar_url")
  provider    AuthProvider
  providerId  String       @map("provider_id")
  tenantId    String       @map("tenant_id")
  role        UserRole     @default(member)
  isOwner     Boolean      @default(false) @map("is_owner")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum InvitationStatus {
  pending
  accepted
  revoked
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  tenantId   String           @map("tenant_id")
  invitedBy  String           @map("invited_by")
  role       UserRole         @default(member)
  status     InvitationStatus @default(pending)
  createdAt  DateTime         @default(now()) @map("created_at")
  expiresAt  DateTime         @map("expires_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@map("invitations")
}
